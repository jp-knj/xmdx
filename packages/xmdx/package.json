{
  "name": "xmdx",
  "version": "0.0.9-next.3",
  "description": "High-performance streaming Markdown to HTML parser built with Rust",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "build:wasm": "cargo build -p xmdx-wasm --target wasm32-unknown-unknown --release && wasm-bindgen ../../target/wasm32-unknown-unknown/release/xmdx_wasm.wasm --out-dir wasm --target web"
  },
  "exports": {
    ".": {
      "node": {
        "types": "./src/node.ts",
        "import": "./src/node.ts",
        "default": "./src/node.ts"
      },
      "browser": {
        "types": "./src/browser.ts",
        "import": "./src/browser.ts",
        "default": "./src/browser.ts"
      },
      "edge-light": {
        "types": "./src/browser.ts",
        "import": "./src/browser.ts",
        "default": "./src/browser.ts"
      },
      "workerd": {
        "types": "./src/browser.ts",
        "import": "./src/browser.ts",
        "default": "./src/browser.ts"
      },
      "default": {
        "types": "./src/browser.ts",
        "import": "./src/browser.ts",
        "default": "./src/browser.ts"
      }
    },
    "./browser": {
      "types": "./src/browser.ts",
      "import": "./src/browser.ts",
      "default": "./src/browser.ts"
    },
    "./registry": {
      "types": "./src/registry/index.ts",
      "import": "./src/registry/index.ts",
      "default": "./src/registry/index.ts"
    },
    "./wasm": {
      "types": "./wasm/xmdx_wasm.d.ts",
      "import": "./wasm/xmdx_wasm.js",
      "default": "./wasm/xmdx_wasm.js"
    },
    "./ops": {
      "types": "./src/ops/index.ts",
      "import": "./src/ops/index.ts",
      "default": "./src/ops/index.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "import": "./src/constants.ts",
      "default": "./src/constants.ts"
    },
    "./utils/mdx-detection": {
      "types": "./src/utils/mdx-detection.ts",
      "import": "./src/utils/mdx-detection.ts",
      "default": "./src/utils/mdx-detection.ts"
    },
    "./utils/imports": {
      "types": "./src/utils/imports.ts",
      "import": "./src/utils/imports.ts",
      "default": "./src/utils/imports.ts"
    },
    "./utils/paths": {
      "types": "./src/utils/paths.ts",
      "import": "./src/utils/paths.ts",
      "default": "./src/utils/paths.ts"
    },
    "./utils/config": {
      "types": "./src/utils/config.ts",
      "import": "./src/utils/config.ts",
      "default": "./src/utils/config.ts"
    },
    "./utils/frontmatter": {
      "types": "./src/utils/frontmatter.ts",
      "import": "./src/utils/frontmatter.ts",
      "default": "./src/utils/frontmatter.ts"
    },
    "./utils/validation": {
      "types": "./src/utils/validation.ts",
      "import": "./src/utils/validation.ts",
      "default": "./src/utils/validation.ts"
    },
    "./transforms": {
      "types": "./src/transforms/index.ts",
      "import": "./src/transforms/index.ts",
      "default": "./src/transforms/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./pipeline": {
      "types": "./src/pipeline/index.ts",
      "import": "./src/pipeline/index.ts",
      "default": "./src/pipeline/index.ts"
    },
    "./compiler": {
      "types": "./src/compiler/index.ts",
      "import": "./src/compiler/index.ts",
      "default": "./src/compiler/index.ts"
    }
  },
  "main": "./src/node.ts",
  "types": "./src/types.ts",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/edge/",
    "wasm"
  ],
  "keywords": [
    "markdown",
    "parser",
    "rust",
    "streaming",
    "performance",
    "html",
    "wasm",
    "mdx"
  ],
  "author": "jp-knj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jp-knj/xmdx"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@xmdx/napi": "workspace:*",
    "gray-matter": "^4.0.3"
  },
  "peerDependencies": {
    "shiki": "^3.22.0",
    "expressive-code": "^0.41.0"
  },
  "peerDependenciesMeta": {
    "shiki": { "optional": true },
    "expressive-code": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "expressive-code": "^0.41.0",
    "miniflare": "^4.0.0",
    "rollup": ">=4.0.0",
    "shiki": "^3.22.0",
    "typescript": "^5.9.0"
  }
}
